rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /friend_requests/{requestId} {
      allow get: if signedIn() && (
        !exists(/databases/$(database)/documents/friend_requests/$(requestId))
        || resource.data.fromUserId == request.auth.uid
        || resource.data.toUserId == request.auth.uid
      );
      allow list: if signedIn() && (
        resource.data.fromUserId == request.auth.uid
        || resource.data.toUserId == request.auth.uid
      );
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.fromUserId != request.resource.data.toUserId
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && resource.data.toUserId == request.auth.uid;
      allow delete: if signedIn()
        && (
          resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid
        );
    }

    match /friendships/{friendshipId} {
      allow get: if signedIn() && (
        !exists(/databases/$(database)/documents/friendships/$(friendshipId))
        || request.auth.uid in resource.data.userIds
      );
      allow list: if signedIn()
        && request.auth.uid in resource.data.userIds;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.userIds;
      allow update: if false;
      allow delete: if signedIn()
        && request.auth.uid in resource.data.userIds;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /news/{newsId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /competitions/{competitionId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /threads/{threadId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /chapters/{chapterId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /direct_messages/{chatId} {
      allow read, write: if signedIn();

      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }

    match /group_chats/{groupId} {
      allow read, write: if signedIn();

      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }

    match /discord_outbox/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.createdBy == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.status in ['pending', 'failed'];
      allow update: if false;
    }

    match /discord_config/{configId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /auth_logs/{logId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }
  }
}
